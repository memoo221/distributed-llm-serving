FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi==0.110.0 uvicorn[standard]==0.27.0 pydantic==2.6.0

COPY master/mock_api.py /app/master/mock_api.py
COPY master/routers/mock_api.py /app/master/routers/mock_api.py
COPY master/routers/__init__.py /app/master/routers/__init__.py

CMD ["uvicorn", "master.mock_api:app", "--host", "0.0.0.0", "--port", "7000"]
