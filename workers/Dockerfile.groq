FROM python:3.11-slim

WORKDIR /app

COPY . .

RUN pip install --no-cache-dir \
    fastapi==0.110.0 \
    uvicorn[standard]==0.27.0 \
    pydantic==2.6.0 \
    httpx==0.27.0 \
    python-dotenv==1.0.1 \
    groq==0.11.0

CMD ["uvicorn", "workers.groq_worker:app", "--host", "0.0.0.0", "--port", "8000"]